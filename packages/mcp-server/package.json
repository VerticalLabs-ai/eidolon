{
  "name": "@eidolon/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server wrapping the Eidolon REST API so Claude Desktop, Cursor, or any MCP client can drive the platform.",
  "bin": {
    "eidolon-mcp-server": "dist/index.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
