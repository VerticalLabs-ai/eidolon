# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Environment (keep tracked templates un-ignored)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Build & generated output
# -----------------------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Tests & coverage
# -----------------------------------------------------------------------------
coverage/
.vitest/

# -----------------------------------------------------------------------------
# Logs & caches
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.parcel-cache
.turbo
.vite/

# -----------------------------------------------------------------------------
# Local data (SQLite, runtime uploads)
# -----------------------------------------------------------------------------
*.db
*.db-journal
*.db-wal
*.db-shm
/data/
eidolon-data/

# -----------------------------------------------------------------------------
# Tooling / IDE (un-ignore shared editor config if you add it later)
# -----------------------------------------------------------------------------
.idea/
.cursor/
.claude/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Stray tsc / tool emit (sources are the adjacent .ts files)
# -----------------------------------------------------------------------------
/vitest.config.js
/vitest.config.js.map
/vitest.config.d.ts
/vitest.config.d.ts.map
/packages/db/drizzle.config.js
/packages/db/drizzle.config.js.map
/packages/db/drizzle.config.d.ts
/packages/db/drizzle.config.d.ts.map
/ui/vite.config.js
/ui/vite.config.js.map
/ui/vite.config.d.ts
/ui/vite.config.d.ts.map
/ui/src/**/*.js
