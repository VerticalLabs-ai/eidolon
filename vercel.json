{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build:vercel",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "ui/dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api|assets|.*\\..*).*)", "destination": "/index.html" }
  ]
}
