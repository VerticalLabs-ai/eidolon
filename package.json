{
  "name": "eidolon",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "pnpm --filter server dev",
    "dev:ui": "pnpm --filter ui dev",
    "build": "pnpm --filter @eidolon/shared build && pnpm --filter server build && pnpm --filter ui build",
    "typecheck": "tsc -b",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "pnpm --filter @eidolon/db generate",
    "db:migrate": "pnpm --filter @eidolon/db migrate",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "rm -rf node_modules packages/*/node_modules server/node_modules ui/node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.1.2",
    "supertest": "^7.2.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
