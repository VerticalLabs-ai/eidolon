# Eidolon - The AI Company Runtime - Environment Configuration

# Server
PORT=3100
NODE_ENV=development

# Database (SQLite - auto-created, no config needed for local dev)
# DATABASE_PATH=./eidolon-data/eidolon.db

# AI Provider API Keys (add the ones you need)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Optional: External storage (default: local disk)
# STORAGE_PROVIDER=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Optional: Telemetry (disabled by default)
EIDOLON_TELEMETRY_DISABLED=1
