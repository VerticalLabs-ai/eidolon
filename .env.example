# Eidolon - The AI Company Runtime - Environment Configuration

# Server
PORT=3100
NODE_ENV=development

# Authentication
# AUTH_MODE=local_trusted  # Set to 'local_trusted' to skip auth (dev only)
AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
ADMIN_EMAIL=                # This email will be auto-promoted to admin on first login

# Google OAuth (optional - enables "Continue with Google" button)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3100/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (SQLite - auto-created, no config needed for local dev)
# DATABASE_PATH=./eidolon-data/eidolon.db

# AI Provider API Keys (add the ones you need)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Optional: External storage (default: local disk)
# STORAGE_PROVIDER=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Optional: Telemetry (disabled by default)
EIDOLON_TELEMETRY_DISABLED=1
