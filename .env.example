# Eidolon — environment configuration example
# Copy to .env or .env.local and replace placeholders for your environment.

# ─── Server ──────────────────────────────────────────────────────────────
# API server port.
PORT=3100
# API bind host.
HOST=127.0.0.1
# Vite UI dev-server port.
UI_PORT=5173
# Node runtime mode.
NODE_ENV=development
# Server log verbosity.
LOG_LEVEL=info
# Graceful shutdown timeout in milliseconds.
SHUTDOWN_TIMEOUT_MS=10000
# Set to 1 to skip serving static UI assets.
EIDOLON_SKIP_STATIC=0
# Operator-owned Ollama endpoint used by execution and model discovery.
EIDOLON_OLLAMA_BASE_URL=http://localhost:11434

# ─── Authentication and authorization ────────────────────────────────────
# Auth mode; use local_trusted only for loopback development.
AUTH_MODE=clerk
# Browser-visible auth mode. Mirror AUTH_MODE for local_trusted development.
VITE_AUTH_MODE=clerk
# Base URL for Better Auth callbacks.
BETTER_AUTH_URL=http://localhost:3100
# Secret used to sign auth/session tokens.
AUTH_SECRET=
# Server-side Clerk secret key.
CLERK_SECRET_KEY=
# Server-side Clerk publishable key fallback.
CLERK_PUBLISHABLE_KEY=
# Browser-safe Clerk publishable key.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Comma-separated emails allowed to sign in.
# Defaults to matt@verticallabs.ai when unset.
# EIDOLON_AUTHORIZED_EMAILS=matt@verticallabs.ai
# Comma-separated emails with admin privileges.
# Defaults to matt@verticallabs.ai when unset.
# EIDOLON_ADMIN_EMAILS=matt@verticallabs.ai

# ─── Google OAuth ────────────────────────────────────────────────────────
# Google OAuth client ID.
GOOGLE_CLIENT_ID=
# Google OAuth client secret.
GOOGLE_CLIENT_SECRET=

# ─── Database and Supabase ───────────────────────────────────────────────
# Default server Postgres connection URL.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres
# Pooled Postgres connection URL.
# POSTGRES_URL=
# Direct Postgres connection URL for migrations.
# POSTGRES_URL_NON_POOLING=
# Prisma-compatible pooled Postgres URL.
# POSTGRES_PRISMA_URL=
# Postgres host.
POSTGRES_HOST=127.0.0.1
# Postgres database name.
POSTGRES_DATABASE=postgres
# Postgres username.
POSTGRES_USER=postgres
# Postgres password.
POSTGRES_PASSWORD=
# Browser-safe Supabase URL.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
# Browser-safe Supabase anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Browser-safe Supabase publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-side Supabase URL.
SUPABASE_URL=http://127.0.0.1:55321
# Server-side Supabase anon key.
SUPABASE_ANON_KEY=
# Server-side Supabase publishable key.
SUPABASE_PUBLISHABLE_KEY=
# Server-side Supabase secret key.
SUPABASE_SECRET_KEY=
# Supabase service-role key.
SUPABASE_SERVICE_ROLE_KEY=
# Supabase JWT secret.
SUPABASE_JWT_SECRET=

# ─── AI providers ────────────────────────────────────────────────────────
# Anthropic API key.
ANTHROPIC_API_KEY=
# OpenAI API key.
OPENAI_API_KEY=
# Google AI API key.
GOOGLE_AI_API_KEY=
# ─── MCP agent runtime ───────────────────────────────────────────────────
# Eidolon API URL for MCP clients.
EIDOLON_API_URL=http://localhost:3100
# API key for MCP clients.
EIDOLON_API_KEY=
# Company ID for MCP client scope.
EIDOLON_COMPANY_ID=
# Agent ID for MCP client scope.
EIDOLON_AGENT_ID=
# Run ID for MCP client sessions.
EIDOLON_RUN_ID=local-dev

# ─── Security, CORS, and cron ────────────────────────────────────────────
# Comma-separated allowed browser origins.
CORS_ORIGIN=http://localhost:5173
# Secret expected by cron endpoints.
CRON_SECRET=
# Encryption key for persisted secrets.
EIDOLON_ENCRYPTION_KEY=
# Set to 1 to enforce CSRF protection outside production.
EIDOLON_ENFORCE_CSRF=0
# Set to 1 to enable request rate limits.
RATE_LIMIT_ENABLED=0

# ─── Desktop packaging and navigation ────────────────────────────────────
# Desktop app URL loaded by Electron.
EIDOLON_DESKTOP_APP_URL=http://localhost:5173
# Comma-separated non-auth hosts allowed in desktop.
EIDOLON_DESKTOP_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated exact non-auth origins allowed in desktop.
EIDOLON_DESKTOP_ALLOWED_ORIGINS=http://127.0.0.1:5173
# Comma-separated auth hosts allowed in desktop.
EIDOLON_DESKTOP_AUTH_HOSTS=accounts.google.com,clerk.accounts.dev
# Set to 1 to require macOS signing config.
EIDOLON_REQUIRE_MAC_SIGNING=0
# macOS signing identity.
APPLE_SIGNING_IDENTITY=Developer ID Application: Example
# Keychain profile for notarization.
APPLE_KEYCHAIN_PROFILE=eidolon-notary-profile
# Keychain name used for signing/notarization.
APPLE_KEYCHAIN=login
# Apple API key path or encoded value.
APPLE_API_KEY=
# Apple API key ID.
APPLE_API_KEY_ID=
# Apple API issuer ID.
APPLE_API_ISSUER=
# Apple ID for notarization fallback.
APPLE_ID=appleid@example.com
# Apple app-specific password for notarization fallback.
APPLE_APP_SPECIFIC_PASSWORD=
# Apple Developer Team ID.
APPLE_TEAM_ID=

# ─── Vite/UI flags ───────────────────────────────────────────────────────
# Browser Clerk key consumed by Vite.
VITE_CLERK_PUBLISHABLE_KEY=
# Version string exposed to the UI.
VITE_APP_VERSION=0.0.0-local
# Set to 1 to enable UI websocket support for self-hosted deployments.
VITE_ENABLE_WEBSOCKET=0
# Vite builtin dev flag; normally supplied by Vite.
DEV=true

# ─── Workspace, telemetry, and platform ──────────────────────────────────
# Workspace root for environment routes.
EIDOLON_WORKSPACE_ROOT=./eidolon-workspace
# Isolated state root for operator-authorized local CLI adapters.
EIDOLON_RUNTIME_HOME=./.eidolon/runtime
# Comma-separated <companyId>:<agentId> pairs allowed to launch local CLIs.
EIDOLON_LOCAL_CLI_ALLOWED_AGENTS=
# Required absolute sandbox launcher providing process, filesystem, and identity isolation.
EIDOLON_LOCAL_CLI_CONTAINMENT_COMMAND=
# Optional fixed launcher arguments as a JSON string array.
EIDOLON_LOCAL_CLI_CONTAINMENT_ARGS_JSON=[]
# Comma-separated non-secret adapterConfig.env keys local CLI agents may set.
EIDOLON_LOCAL_CLI_ENV_ALLOWLIST=
# Exact process:local argv presets; command paths must be canonical real paths.
EIDOLON_PROCESS_COMMAND_ALLOWLIST_JSON=[]
# JSON map of trusted HTTP/OpenClaw origins to the exact IPs they may use.
EIDOLON_RUNTIME_HTTP_ORIGIN_ALLOWLIST_JSON={}
# Optional absolute executable overrides; PATH discovery is used when blank.
EIDOLON_CODEX_CLI_COMMAND=
EIDOLON_CLAUDE_CLI_COMMAND=
# HTTPS OpenAI Responses-compatible gateway used by codex_local.
EIDOLON_CODEX_GATEWAY_URL=
# Absolute operator-owned helper that prints one short-lived gateway token.
EIDOLON_CODEX_GATEWAY_TOKEN_COMMAND=
# HTTPS Anthropic-compatible gateway used by claude_local.
EIDOLON_CLAUDE_GATEWAY_URL=
# Absolute operator-owned helper that prints one short-lived gateway token.
EIDOLON_CLAUDE_GATEWAY_TOKEN_COMMAND=
# Set to 1 to disable telemetry.
EIDOLON_TELEMETRY_DISABLED=1
# Vercel OIDC token supplied by Vercel CLI.
VERCEL_OIDC_TOKEN=
