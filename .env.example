# Eidolon — environment configuration

# ─── Server ──────────────────────────────────────────────────────────────
PORT=3100
NODE_ENV=development

# ─── Authentication (Clerk via Vercel Marketplace) ───────────────────────
#
# Both keys are provisioned automatically by `vercel integration add clerk`.
# Pull them locally with: `vercel env pull .env.local`
#
# Dev bypass: set AUTH_MODE=local_trusted to skip Clerk entirely (loopback
# single-operator only — never run this on a network-reachable host).
# AUTH_MODE=local_trusted

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Vite exposes only env vars prefixed with VITE_ to the browser bundle.
# vite.config.ts falls back to NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY when this
# is empty so the Marketplace-provisioned name works directly.
VITE_CLERK_PUBLISHABLE_KEY=

# ─── Database (SQLite — auto-created) ────────────────────────────────────
# DATABASE_URL=./data/eidolon.db

# ─── AI Provider API Keys (add the ones you need) ────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ─── Rate limit (opt-in outside production) ──────────────────────────────
# RATE_LIMIT_ENABLED=1

# ─── CORS allowlist (comma-separated origins) ────────────────────────────
# CORS_ORIGIN=https://app.example.com

# ─── Optional: external storage (default: local disk) ────────────────────
# STORAGE_PROVIDER=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ─── Telemetry (disabled by default) ─────────────────────────────────────
EIDOLON_TELEMETRY_DISABLED=1
